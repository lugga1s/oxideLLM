[server]
host = "127.0.0.1"
port = 8080
# Maximum request body size accepted by the gateway.
# request_body_max_bytes = 10485760
# Upstream connection timeout in milliseconds.
# upstream_connect_timeout_ms = 5000
# Upstream request timeout in milliseconds.
# upstream_request_timeout_ms = 120000

[[upstreams]]
id = "mock-primary"
# Choose the upstream provider: "mock" (default) or "ollama" (local OpenAI-compatible).
provider = "mock"
# Default for mock: http://127.0.0.1:9000
# Default for ollama: http://127.0.0.1:11434
base_url = "http://127.0.0.1:9000"
priority = 10
# Default for mock upstreams: /healthz
health_path = "/healthz"

[[upstreams]]
id = "ollama-local"
provider = "ollama"
base_url = "http://127.0.0.1:11434"
priority = 20
# Default for ollama upstreams: /api/tags
health_path = "/api/tags"

# Lower priority numbers are tried first by failover logic.
# The legacy [upstream] table is still accepted for single-upstream configs.

[upstream_health]
# Background worker interval for checking configured upstreams.
interval_ms = 5000
# Per-upstream request timeout for the health check.
timeout_ms = 1000

[telemetry]
capacity = 65536
log_path = "telemetry_events.jsonl"
batch_size = 1000
flush_interval_ms = 500
