{
  "rust_validation": [
    ".\\scripts\\validate_context.ps1",
    "cargo fmt --check",
    "cargo check --all-targets",
    "cargo test --all",
    "cargo clippy --all-targets -- -D warnings"
  ],
  "run_gateway": [
    "cargo run -- --host 127.0.0.1 --port 8080",
    "cargo run --release -- --host 127.0.0.1 --port 8080"
  ],
  "mock": [
    "docker build -t llmk-mock ./mock",
    "docker run --rm -p 9000:9000 llmk-mock"
  ],
  "k6": [
    "k6 run -e TARGET_URL=http://localhost:9000/v1/chat/completions k6/proxy-vs-direct.js",
    "k6 run -e TARGET_URL=http://localhost:8080/v1/chat/completions k6/proxy-vs-direct.js"
  ],
  "git": [
    "git checkout -b feature/stage-02-sse-passthrough",
    "git push -u origin feature/stage-02-sse-passthrough",
    "gh pr create --draft --title \"Stage 2: SSE passthrough baseline\""
  ]
}
